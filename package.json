    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "@tailwindcss/postcss": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^6.0.0",
    "vitest": "^2.0.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.8",
    "jsdom": "^25.0.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3"
